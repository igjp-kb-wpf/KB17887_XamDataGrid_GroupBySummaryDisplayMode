<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:igDP="http://infragistics.com/DataPresenter"
        mc:Ignorable="d"
        Title="GroupBy Summary サンプル"
        Height="700" Width="800">

    <DockPanel Margin="4">
        <TextBlock DockPanel.Dock="Top"
                   Text="GroupBySummaryDisplayMode = SummaryCellsAlwaysBelowDescription"
                   FontWeight="Bold" FontSize="14"
                   TextWrapping="Wrap"
                   Margin="0,4,0,4"/>

        <igDP:XamDataGrid x:Name="GridRight"
                          Theme="Office2013"
                          GroupByAreaLocation="None">

            <igDP:XamDataGrid.FieldSettings>
                <igDP:FieldSettings AllowEdit="False"
                    AllowRecordFiltering="True"
                    CellClickAction="SelectRecord"
                    FilterOperatorDefaultValue="Contains"/>
            </igDP:XamDataGrid.FieldSettings>

            <!--
                    ■ GroupBySummaryDisplayMode について

                    GroupBy でグループ化した際に、各グループ行に対して
                    サマリー（集計値）をどのように表示するかを制御するプロパティです。

                    主な設定値:
                    ・Default（Text）
                        既定の動作。
                        集計はグループ化レコードの説明に付加される
                        プレーン テキストで表示されます。
                        各集計は集計の値が後ろに続く列名で表示されます。
                        複数の集計はコンマ文字（‘,’）によって区切られます。

                    ・SummaryCellsAlwaysBelowDescription  ← 今回の設定
                        各集計は、グループ化レコードに関連付けられた
                        フィールドと配置されるセルとして表示されます。
                        グループ化レコードに説明がある場合、集計セルは説明の下に表示されます。


                    参考: FieldLayoutSettings.GroupBySummaryDisplayMode プロパティ
                    https://jp.infragistics.com/help/wpf/infragisticswpf.datapresenter~infragistics.windows.datapresenter.fieldlayoutsettings~groupbysummarydisplaymode
                -->

            <igDP:XamDataGrid.FieldLayoutSettings>
                <igDP:FieldLayoutSettings
                    AutoGenerateFields="False"
                    HeaderPlacementInGroupBy="OnTopOnly"
                    AllowDelete="False"
                    GroupBySummaryDisplayMode="SummaryCellsAlwaysBelowDescription"/>
            </igDP:XamDataGrid.FieldLayoutSettings>

            <igDP:XamDataGrid.FieldLayouts>
                <igDP:FieldLayout>

                    <igDP:FieldLayout.SortedFields>
                        <igDP:FieldSortDescription FieldName="MONTH"
                                                   Direction="Ascending"
                                                   IsGroupBy="True"/>
                    </igDP:FieldLayout.SortedFields>

                    <igDP:FieldLayout.Fields>
                        <igDP:Field Name="MONTH"        Label="月"/>
                        <igDP:Field Name="COMPANY_NAME" Label="会社名"/>
                        <igDP:Field Name="PRODUCT_NAME" Label="製品名"/>
                        <igDP:Field Name="QUANTITY"     Label="数量"
                                    Format="#,###,##0"/>
                        <igDP:Field Name="AMOUNT"       Label="金額"
                                    Format="#,###,##0"/>
                    </igDP:FieldLayout.Fields>

                    <igDP:FieldLayout.SummaryDefinitions>
                        <igDP:SummaryDefinition SourceFieldName="PRODUCT_NAME"
                                                Calculator="Count"
                                                StringFormat="合計"/>
                        <igDP:SummaryDefinition SourceFieldName="QUANTITY"
                                                Calculator="Sum"
                                                StringFormat="{}{0:#,###,##0}"/>
                        <igDP:SummaryDefinition SourceFieldName="AMOUNT"
                                                Calculator="Sum"
                                                StringFormat="{}{0:#,###,##0}"/>
                    </igDP:FieldLayout.SummaryDefinitions>

                </igDP:FieldLayout>
            </igDP:XamDataGrid.FieldLayouts>
        </igDP:XamDataGrid>
    </DockPanel>
</Window>
